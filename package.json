{
    "name": "aljazmc",
    "version": "0.0.0",
    "author": "aljazmc",
    "license": "MIT",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/aljazmc/aljazmc.git"
    },
    "packageManager": "yarn@4.12.0",
    "workspaces": [
        "packages/**"
    ],
    "dependencies": {
        "@aljazmc/formatero": "workspace:*",
        "@aljazmc/lintero": "workspace:*",
        "@aljazmc/monorepo": "workspace:*",
        "@aljazmc/read-it": "workspace:*",
        "@aljazmc/ship-it": "workspace:*",
        "@aljazmc/tag-it": "workspace:*",
        "@aljazmc/testero": "workspace:*",
        "@aljazmc/zip-it": "workspace:*"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.5",
        "@types/jest": "^30.0.0",
        "esbuild": "0.27.3",
        "esbuild-register": "^3.6.0",
        "jest": "^30.2.0",
        "jest-esbuild": "^0.4.0",
        "typescript": "^5.9.3",
        "unrs-resolver": "^1.11.1"
    },
    "resolutions": {
        "esbuild": "0.27.3"
    },
    "engines": {
        "node": ">=25.3.0",
        "npm": "Please use yarn instead of NPM to install dependencies",
        "pnpm": "Please use yarn instead of PNPM to install dependencies",
        "yarn": ">=4.12.0"
    },
    "scripts": {
        "b:all": "yarn workspaces foreach -A run build",
        "b:formatero": "yarn workspace @aljazmc/formatero run build",
        "b:lintero": "yarn workspace @aljazmc/lintero run build",
        "b:monorepo": "yarn workspace @aljazmc/monorepo run build",
        "b:read-it": "yarn workspace @aljazmc/read-it run build",
        "b:ship-it": "yarn workspace @aljazmc/ship-it run build",
        "b:tag-it": "yarn workspace @aljazmc/tag-it run build",
        "b:testero": "yarn workspace @aljazmc/testero run build",
        "b:zip-it": "yarn workspace @aljazmc/zip-it run build",
        "c:all": "yarn workspaces foreach -A run complete",
        "c:formatero": "yarn workspace @aljazmc/formatero run complete",
        "c:lintero": "yarn workspace @aljazmc/lintero run complete",
        "c:monorepo": "yarn workspace @aljazmc/monorepo run complete",
        "c:read-it": "yarn workspace @aljazmc/read-it run complete",
        "c:ship-it": "yarn workspace @aljazmc/ship-it run complete",
        "c:tag-it": "yarn workspace @aljazmc/tag-it run complete",
        "c:testero": "yarn workspace @aljazmc/testero run complete",
        "c:zip-it": "yarn workspace @aljazmc/zip-it run complete",
        "ct:all": "yarn workspaces foreach -A run checktypes",
        "ct:formatero": "tsc --noEmit packages/formatero",
        "ct:lintero": "tsc --noEmit packages/lintero",
        "ct:monorepo": "tsc --noEmit packages/monorepo",
        "ct:read-it": "tsc --noEmit packages/read-it",
        "ct:ship-it": "tsc --noEmit packages/ship-it",
        "ct:tag-it": "tsc --noEmit packages/tag-it",
        "ct:testero": "tsc -noEmit packages/testero",
        "ct:zip-it": "tsc -noEmit packages/zip-it",
        "et:all": "yarn workspaces foreach -A run exporttypes",
        "et:formatero": "tsc -b packages/formatero",
        "et:lintero": "tsc -b packages/lintero",
        "et:monorepo": "tsc -b packages/monorepo",
        "et:read-it": "tsc -b packages/read-it",
        "et:ship-it": "tsc -b packages/ship-it",
        "et:tag-it": "tsc -b packages/tag-it",
        "et:testero": "tsc -b packages/testero",
        "et:zip-it": "tsc -b packages/zip-it",
        "lint": "biome check",
        "lint:w": "biome check --write",
        "lint:wu": "biome check --write --unsafe",
        "t:all": "yarn test",
        "t:coverage": "yarn t:all --coverage",
        "t:formatero": "jest packages/formatero",
        "t:lintero": "jest packages/lintero",
        "t:monorepo": "jest packages/monorepo",
        "t:read-it": "jest packages/read-it",
        "t:ship-it": "jest packages/ship-it",
        "t:tag-it": "jest packages/tag-it",
        "t:testero": "jest packages/testero",
        "t:zip-it": "jest packages/zip-it",
        "test": "jest",
        "test:w": "jest --watchAll",
        "typecheck:w": "tsc --noEmit --watch"
    }
}
