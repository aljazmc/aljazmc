{
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "emitDeclarationOnly": true,
        "esModuleInterop": true,
        "exactOptionalPropertyTypes": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,
        "listEmittedFiles": true,
        "module": "nodenext",
        "moduleDetection": "force",
        "moduleResolution": "nodenext",
        "noUncheckedIndexedAccess": true,
        "noUncheckedSideEffectImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "es2022",
        "types": ["node"],
        "verbatimModuleSyntax": true,
        "paths": {
            "@aljazmc/formatero": ["./packages/formatero"],
            "@aljazmc/lintero": ["./packages/lintero"],
            "@aljazmc/monorepo": ["./packages/monorepo"],
            "@aljazmc/testero": ["./packages/testero"]
        }
    },
    "exclude": ["jest.config.ts", "**/bin", "**/tests"],
    "references": [
        {
            "path": "./packages/formatero"
        },
        {
            "path": "./packages/lintero"
        },
        {
            "path": "./packages/monorepo"
        },
        {
            "path": "./packages/testero"
        }
    ]
}
